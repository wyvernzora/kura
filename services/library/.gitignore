# Binaries and build output
bin/
dist/
build/
tmp/
*.exe
*.dll
*.so
*.dylib
*.test

# Web UI: keep the embed package's placeholder index.html tracked so
# `go build` always finds something to embed; the real Vite output
# (assets/, hashed JS/CSS, route chunks) is generated and ignored.
!internal/server/webui/dist/
internal/server/webui/dist/*
!internal/server/webui/dist/index.html

# Node / web tooling
node_modules/
.vite/
*.tsbuildinfo
pnpm-debug.log
.pnpm-store/

# Go workspace and coverage artifacts
go.work
coverage.out
*.coverprofile

# Environment and local configuration
.env
.env.*
!.env.example
.envrc
*.private.*
LOCAL_NOTES.md
docs/LOCAL.md
.local/
scratch
.claude
.codex

# Editor and OS files
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log
