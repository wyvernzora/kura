# stage_attrs_refresh_clears: restaging without attrs replaces the map
# wholesale, so absent attrs clear the staged record.

kura_add stub:1001
kura_mkfile ep1.mp4

kura_stage_attrs $KURA_LAST_REF S01E0001 ep1.mp4 origin=takuhai
stdout '"attrs":{"origin":"takuhai"}'
kura_show $KURA_LAST_REF
stdout '"attrs":{"origin":"takuhai"}'

kura_stage_replace $KURA_LAST_REF S01E0001 ep1.mp4
stdout '"status":"replaced"'
kura_show $KURA_LAST_REF
stdout '"status":"staged"'
! stdout '"attrs"'
