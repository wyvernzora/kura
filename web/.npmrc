# Project-scoped override for ~/.npmrc's `ignore-scripts=true` hardening.
#
# kura/web uses pnpm 10+, which already ignores dependency install scripts
# by default and uses the `allowBuilds` allowlist in pnpm-workspace.yaml
# to opt specific packages (@biomejs/biome, esbuild) back in. The global
# `ignore-scripts=true` is a hard toggle that would override that
# allowlist, leaving esbuild without its native binary and biome unable
# to install.
#
# Setting ignore-scripts=false here restores pnpm 10's secure default
# (scripts off except allowBuilds entries), which is the correct
# posture for this project.
ignore-scripts=false
