{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trash_v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/trash"
      }
    }
  },
  "$defs": {
    "trash": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "season",
        "number",
        "media",
        "companions"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "season": {
          "type": "integer",
          "minimum": 0
        },
        "number": {
          "type": "integer",
          "minimum": 1
        },
        "media": {
          "$ref": "#/$defs/mediaFile"
        },
        "companions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/companionFile"
          }
        }
      }
    },
    "mediaFile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "source",
        "size",
        "mtime"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "size": {
          "type": "integer",
          "minimum": 0
        },
        "mtime": {
          "type": "string",
          "minLength": 1
        },
        "sampleHash": {
          "type": "string"
        },
        "mediainfo": {
          "$ref": "#/$defs/mediaInfo"
        }
      }
    },
    "companionFile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "size",
        "mtime"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "role": {
          "type": "string"
        },
        "language": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "size": {
          "type": "integer",
          "minimum": 0
        },
        "mtime": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "mediaInfo": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "videoCodec": {
          "type": "string"
        },
        "resolution": {
          "type": "string"
        },
        "audioCodec": {
          "type": "string"
        },
        "hasSubtitles": {
          "type": "boolean"
        }
      }
    },
    "relativePath": {
      "type": "string",
      "minLength": 1
    }
  }
}
