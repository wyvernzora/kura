{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "series_v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "providerRefs",
    "preferredProvider",
    "preferredTitle",
    "canonicalTitle"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "providerRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[^:]+:.+$"
      }
    },
    "preferredProvider": {
      "type": "string",
      "minLength": 1
    },
    "preferredTitle": {
      "type": "string",
      "minLength": 1
    },
    "canonicalTitle": {
      "type": "string",
      "minLength": 1
    },
    "filesystemTitle": {
      "type": "string",
      "minLength": 1
    },
    "lastScanned": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "string"
    },
    "seasons": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/season"
      }
    },
    "specials": {
      "$ref": "#/$defs/season"
    }
  },
  "$defs": {
    "season": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "number"
      ],
      "properties": {
        "number": {
          "type": "integer",
          "minimum": 0
        },
        "notes": {
          "type": "string"
        },
        "episodes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/episode"
          }
        }
      }
    },
    "episode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "number",
        "media",
        "companions"
      ],
      "properties": {
        "number": {
          "type": "integer",
          "minimum": 1
        },
        "media": {
          "$ref": "#/$defs/mediaFile"
        },
        "companions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/companionFile"
          }
        }
      }
    },
    "mediaFile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "source",
        "size",
        "mtime"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "size": {
          "type": "integer",
          "minimum": 0
        },
        "mtime": {
          "type": "string",
          "minLength": 1
        },
        "sampleHash": {
          "type": "string"
        },
        "mediainfo": {
          "$ref": "#/$defs/mediaInfo"
        }
      }
    },
    "companionFile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "size",
        "mtime"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "role": {
          "type": "string"
        },
        "language": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "size": {
          "type": "integer",
          "minimum": 0
        },
        "mtime": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "mediaInfo": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "videoCodec": {
          "type": "string"
        },
        "resolution": {
          "type": "string"
        },
        "audioCodec": {
          "type": "string"
        },
        "hasSubtitles": {
          "type": "boolean"
        }
      }
    },
    "relativePath": {
      "type": "string",
      "minLength": 1
    }
  }
}
