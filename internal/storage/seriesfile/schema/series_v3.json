{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "metadataRef", "episodes", "searchKey"],
  "properties": {
    "schemaVersion": { "const": 3 },
    "metadataRef": { "type": "string", "minLength": 1 },
    "preferredTitle": { "type": "string" },
    "canonicalTitle": { "type": "string" },
    "lastScanned": { "type": "string" },
    "ordering": { "type": "string" },
    "artwork": { "$ref": "#/$defs/artwork" },
    "episodes": {
      "type": "object",
      "propertyNames": {
        "pattern": "^S[0-9]{2,}E[0-9]{4,}$"
      },
      "additionalProperties": { "$ref": "#/$defs/episode" }
    },
    "stagedTrash": {
      "type": "array",
      "items": { "$ref": "#/$defs/stagedTrashEntry" }
    },
    "stagedExtras": {
      "type": "array",
      "items": { "$ref": "#/$defs/stagedExtraEntry" }
    },
    "userAliases": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "searchKey": { "type": "string" },
    "in_progress": { "$ref": "#/$defs/holder" },
    "last_mutated": { "$ref": "#/$defs/mutator" }
  },
  "$defs": {
    "holder": {
      "type": "object",
      "additionalProperties": false,
      "required": ["op", "pid", "host", "started"],
      "properties": {
        "op": { "type": "string", "minLength": 1 },
        "token": { "type": "string" },
        "pid": { "type": "integer" },
        "host": { "type": "string", "minLength": 1 },
        "started": { "type": "string", "minLength": 1 }
      }
    },
    "mutator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["op", "pid", "host", "at"],
      "properties": {
        "op": { "type": "string", "minLength": 1 },
        "pid": { "type": "integer" },
        "host": { "type": "string", "minLength": 1 },
        "at": { "type": "string", "minLength": 1 }
      }
    },
    "episode": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "airDate": { "type": "string" },
        "preferredTitle": { "type": "string" },
        "canonicalTitle": { "type": "string" },
        "active": { "$ref": "#/$defs/mediaRecord" },
        "staged": { "$ref": "#/$defs/mediaRecord" }
      }
    },
    "artwork": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "poster": { "$ref": "#/$defs/poster" }
      }
    },
    "poster": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url"],
      "properties": {
        "url": { "type": "string", "minLength": 1 },
        "thumbnailUrl": { "type": "string" },
        "language": { "type": "string" }
      }
    },
    "mediaRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "source", "size", "mtime", "companions"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "source": { "type": "string" },
        "resolution": { "type": "string" },
        "codec": { "type": "string" },
        "size": { "type": "integer", "minimum": 0 },
        "mtime": { "type": "string" },
        "companions": {
          "type": "array",
          "items": { "$ref": "#/$defs/companionRecord" }
        }
      }
    },
    "companionRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "size", "mtime"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "role": { "type": "string" },
        "language": { "type": "string" },
        "label": { "type": "string" },
        "size": { "type": "integer", "minimum": 0 },
        "mtime": { "type": "string" }
      }
    },
    "stagedTrashEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "size", "mtime", "addedAt", "companions"],
      "properties": {
        "id": { "type": "string", "minLength": 26, "maxLength": 26 },
        "path": { "type": "string", "minLength": 1 },
        "size": { "type": "integer", "minimum": 0 },
        "mtime": { "type": "string" },
        "addedAt": { "type": "string" },
        "companions": {
          "type": "array",
          "items": { "$ref": "#/$defs/companionRecord" }
        }
      }
    },
    "stagedExtraEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "season", "path", "addedAt"],
      "properties": {
        "id": { "type": "string", "minLength": 26, "maxLength": 26 },
        "season": { "type": "integer", "minimum": 0 },
        "path": { "type": "string", "minLength": 1 },
        "prefix": { "type": "string" },
        "isDir": { "type": "boolean" },
        "addedAt": { "type": "string" }
      }
    }
  }
}
