{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "metadataRef", "episodes"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "metadataRef": { "type": "string", "minLength": 1 },
    "lastScanned": { "type": "string" },
    "episodes": {
      "type": "object",
      "propertyNames": {
        "pattern": "^S[0-9]{2,}E[0-9]{4,}$"
      },
      "additionalProperties": { "$ref": "#/$defs/episode" }
    }
  },
  "$defs": {
    "episode": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "season": { "type": "integer", "minimum": 0 },
        "episode": { "type": "integer", "minimum": 1 },
        "airDate": { "type": "string" },
        "active": { "$ref": "#/$defs/mediaRecord" },
        "staged": { "$ref": "#/$defs/mediaRecord" }
      }
    },
    "mediaRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "source", "size", "mtime", "companions"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "source": { "type": "string" },
        "resolution": { "type": "string" },
        "codec": { "type": "string" },
        "size": { "type": "integer", "minimum": 0 },
        "mtime": { "type": "string" },
        "companions": {
          "type": "array",
          "items": { "$ref": "#/$defs/companionRecord" }
        }
      }
    },
    "companionRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "size", "mtime"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "role": { "type": "string" },
        "language": { "type": "string" },
        "label": { "type": "string" },
        "size": { "type": "integer", "minimum": 0 },
        "mtime": { "type": "string" }
      }
    }
  }
}
